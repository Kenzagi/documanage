# =============================================================================
# DocuManage - Git Ignore Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
bun.lockb

# -----------------------------------------------------------------------------
# Build Output
# -----------------------------------------------------------------------------
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# Database (Development)
# -----------------------------------------------------------------------------
*.db
*.db-journal
prisma/*.db
prisma/*.db-journal

# -----------------------------------------------------------------------------
# Environment Variables
# -----------------------------------------------------------------------------
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dev.log
server.log

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# -----------------------------------------------------------------------------
# OS Generated Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------------
# Vercel
# -----------------------------------------------------------------------------
.vercel/

# -----------------------------------------------------------------------------
# Uploaded Files (user data - should not be committed)
# -----------------------------------------------------------------------------
uploads/
upload/

# -----------------------------------------------------------------------------
# Generated Reports & Exports
# -----------------------------------------------------------------------------
download/*.pdf
download/*.xlsx
download/*.py
download/*.csv

# -----------------------------------------------------------------------------
# Temporary & Cache Files
# -----------------------------------------------------------------------------
*.tmp
*.temp
.cache/
.parcel-cache/
.turbo/

# -----------------------------------------------------------------------------
# Security & Secrets
# -----------------------------------------------------------------------------
*.pem
*.key
secrets/

# -----------------------------------------------------------------------------
# Development Tools
# -----------------------------------------------------------------------------
.claude/
.z-ai-config/
skills/
test/
prompt/
local-*

# -----------------------------------------------------------------------------
# Examples (not needed for production)
# -----------------------------------------------------------------------------
examples/
