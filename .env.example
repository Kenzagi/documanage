# DocuManage Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL for Vercel)
# =============================================================================
# For Vercel deployment, use Vercel Postgres or Neon
# These will be auto-filled when you connect Vercel Storage

# Example for Vercel Postgres (auto-provided by Vercel):
# DATABASE_URL="postgres://default:xxxxx@ep-xxxxx.us-east-1.aws.neon.tech/verceldb?sslmode=require"
# DIRECT_DATABASE_URL="postgres://default:xxxxx@ep-xxxxx.us-east-1.aws.neon.tech/verceldb?sslmode=require"

# For local development with SQLite:
# DATABASE_URL="file:./dev.db"

# =============================================================================
# AUTHENTICATION
# =============================================================================
# JWT secret key - MUST be changed in production
# Generate a secure key: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Environment: development, test, production
NODE_ENV="development"
